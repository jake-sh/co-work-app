rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    // User profiles: readable by any authenticated user (needed for member lookup),
    // writable only by the owner.
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // Projects: members can read; any auth'd user can create;
    // only members can update/delete.
    match /projects/{projectId} {
      allow read: if isAuth() && request.auth.uid in resource.data.memberIds;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid in resource.data.memberIds;

      function isMember() {
        return isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
      }

      // Todos, schedule events, and chat messages: visible to any project
      // member (no per-document sharing concept).
      match /todos/{todoId} {
        allow read, write: if isMember();
      }
      match /schedule/{eventId} {
        allow read, write: if isMember();
      }
      match /messages/{messageId} {
        allow read, write: if isMember();
      }

      // Memos: only visible to their author and whoever they're shared
      // with, even though every member is a project member.
      match /memos/{memoId} {
        allow read: if isMember()
          && (resource.data.authorId == request.auth.uid
            || request.auth.uid in resource.data.sharedWith);
        allow create: if isMember() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isMember()
          && (resource.data.authorId == request.auth.uid
            || request.auth.uid in resource.data.sharedWith);
      }
    }
  }
}
